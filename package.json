{
  "name": "scan-market-app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "codegen": "rm -rf src/contracts && sui-ts-codegen generate",
    "scan": "tsx scripts/scanner-node.ts",
    "verify": "tsx scripts/verify-scans.ts",
    "verify:once": "tsx scripts/verify-scans.ts --once",
    "tlsn:notary": "docker run -d --name tlsn-notary -p 7047:7047 ghcr.io/tlsnotary/tlsn/notary-server:v0.1.0-alpha.12",
    "tlsn:prove": "tsx scripts/tlsn-prove.ts",
    "tlsn:verify": "tsx scripts/tlsn-verify.ts"
  },
  "dependencies": {
    "@mysten/dapp-kit-react": "^2.0.3",
    "@mysten/sui": "^2.16.2",
    "@nanostores/react": "^1.0.0",
    "@tanstack/react-query": "^5.90.16",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "tlsn-js": "0.1.0-alpha.12.0",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@mysten/codegen": "^0.10.6",
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "playwright": "^1.60.0",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vite": "^8.0.5"
  }
}
